# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/
/dist-ssr/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local caches / tooling（再生成可能・ローカル専用）
/.tanstack
/.convex
/.agents

# 同期コンフリクトの重複ファイル（push しない）
* 2.*

# セッション引き継ぎファイル（ローカル専用・コミットしない）
HANDOFF.md

# 失敗ログ（ローカル専用・GitHub に上げない）
docs/失敗ログ_卓注文.md
.env*
